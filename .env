# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  SecureDevIQ — environment variables                                    ║
# ║  Copy to .env and fill in the values for your chosen AI provider.       ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── AI Provider ────────────────────────────────────────────────────────────────
# Choose which LLM backend to use.  Valid values: anthropic | qwen
AI_PROVIDER=qwen

# ── Anthropic (required when AI_PROVIDER=anthropic) ────────────────────────────
# Obtain at: https://console.anthropic.com/
#ANTHROPIC_API_KEY=sk-ant-...
# Model to use.  Default: claude-sonnet-4-20250514
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Qwen / DashScope (required when AI_PROVIDER=qwen) ─────────────────────────
# Obtain at: https://www.alibabacloud.com/help/model-studio/get-api-key
DASHSCOPE_API_KEY=sk-078ddf1236a34c6e84e1e09fca1059ec
#
# Model to use.  Options (best → fastest):
#   qwen-max   — highest capability, slower, more expensive
#   qwen-plus  — good balance (default)
#   qwen-turbo — fastest, cheapest
# QWEN_MODEL=qwen-plus
#
# Regional endpoint — use the one closest to you:
#   International (Singapore / US):  https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#   China (Beijing):                 https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=securedeviq
POSTGRES_PASSWORD=securedeviq_secret
POSTGRES_DB=securedeviq

# ── Backend ────────────────────────────────────────────────────────────────────
# Set manually only when running outside Docker.
# Docker Compose assembles this from the POSTGRES_* vars above.
DATABASE_URL=postgresql+asyncpg://securedeviq:securedeviq_secret@localhost:5432/securedeviq

# ── Auth (JWT) ─────────────────────────────────────────────────────────────────
# Generate with:  openssl rand -hex 32
SECRET_KEY=4d89ef9325c1a10f3c8e72a1d9b6f4e8c0a27db15f39c62e8a74d5c91fb30ea6

# ── Frontend ───────────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
