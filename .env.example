# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  SecureDevIQ — environment variables                                    ║
# ║  Copy to .env and fill in the values for your chosen AI provider.       ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── AI Provider ────────────────────────────────────────────────────────────────
# Choose which LLM backend to use.  Valid values: anthropic | qwen | openrouter
AI_PROVIDER=anthropic

# ── Anthropic (required when AI_PROVIDER=anthropic) ────────────────────────────
# Obtain at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
# Model to use.  Default: claude-sonnet-4-20250514
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Qwen / DashScope (required when AI_PROVIDER=qwen) ─────────────────────────
# Obtain at: https://www.alibabacloud.com/help/model-studio/get-api-key
# DASHSCOPE_API_KEY=sk-...
#
# Model to use.  Options (best → fastest):
#   qwen-max   — highest capability, slower, more expensive
#   qwen-plus  — good balance (default)
#   qwen-turbo — fastest, cheapest
# QWEN_MODEL=qwen-plus
#
# Regional endpoint — use the one closest to you:
#   International (Singapore / US):  https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#   China (Beijing):                 https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ── Openrouter (required when AI_PROVIDER=openrouter) ──────────────────────────
# Obtain at: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-...
#
# Model to use. Supported models: https://openrouter.ai/docs/models
# Some popular options:
#   openai/gpt-4-turbo           — Most capable, recommended
#   openai/gpt-3.5-turbo         — Cheaper, faster
#   anthropic/claude-3-sonnet    — Alternative Claude model
#   meta-llama/llama-2-70b-chat  — Open source alternative
# OPENROUTER_MODEL=openai/gpt-4-turbo
#
# Openrouter endpoint (should not need to change)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=securedeviq
POSTGRES_PASSWORD=securedeviq_secret
POSTGRES_DB=securedeviq

# ── Backend ────────────────────────────────────────────────────────────────────
# Set manually only when running outside Docker.
# Docker Compose assembles this from the POSTGRES_* vars above.
DATABASE_URL=postgresql+asyncpg://securedeviq:securedeviq_secret@localhost:5432/securedeviq

# ── Auth (JWT) ─────────────────────────────────────────────────────────────────
# Generate with:  openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ── Frontend ───────────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:7429

# ── Docker Compose Ports (customize to avoid port conflicts) ──────────────────────
# Backend API port (default: 7429 to avoid common port clashes)
BACKEND_PORT=7429
# Frontend port (default: 5173 to avoid common port clashes)
FRONTEND_PORT=5173
# Frontend WebSocket port (default: 5174 to avoid common port clashes)
FRONTEND_WEBSOCKET_PORT=5174
