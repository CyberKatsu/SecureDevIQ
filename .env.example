# ── Anthropic ─────────────────────────────────────────────────────────────────
# Obtain from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=securedeviq
POSTGRES_PASSWORD=securedeviq_secret
POSTGRES_DB=securedeviq

# ── Backend ────────────────────────────────────────────────────────────────────
# Used directly by the backend service; Docker Compose assembles it automatically.
# Set this manually only if running outside Docker.
DATABASE_URL=postgresql+asyncpg://securedeviq:securedeviq_secret@localhost:5432/securedeviq

# ── Frontend ───────────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
